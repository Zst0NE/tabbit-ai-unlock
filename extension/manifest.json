{
  "manifest_version": 3,
  "name": "Tabbit 原生 Chat 自有 API",
  "version": "1.5.5",
  "description": "在官方 Chat 页注入 API 桥：拦截 /chat/send，可选走 OpenAI/Anthropic。",
  "permissions": ["storage", "scripting", "tabs", "webNavigation"],
  "host_permissions": [
    "https://web.tabbit-ai.com/*",
    "https://web.tabbit.com/*",
    "https://*.tabbit-ai.com/*",
    "https://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.tabbit-ai.com/*",
        "https://web.tabbit.com/*",
        "https://*.tabbit-ai.com/*",
        "https://*.tabbit.com/*"
      ],
      "js": ["native_bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "打开官方 Chat 并显示 API 按钮",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
